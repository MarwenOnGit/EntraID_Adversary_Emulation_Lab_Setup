# IGNORE the Evilginx2 source code directory
Initial Access Tactics/evilginx-strat/evilginx2/

# BUT track everything else in the evilginx-strat folder
!Initial Access Tactics/evilginx-strat/

# Terraform sensitive files
terraform_evilginx/.terraform/
terraform_evilginx/.terraform.lock.hcl
terraform_evilginx/terraform.tfstate
terraform_evilginx/terraform.tfstate.*
terraform_evilginx/terraform.tfvars
terraform_evilginx/terraform.tfvars.json
terraform_evilginx/crash.log
terraform_evilginx/crash.*.log
terraform_evilginx/override.tf
terraform_evilginx/override.tf.json
terraform_evilginx/*_override.tf
terraform_evilginx/*_override.tf.json
terraform_evilginx/.terraformrc
terraform_evilginx/terraform.rc
terraform_evilginx/ansible.log
terraform_evilginx/keys/*
terraform_evilginx/.tfsate.lock.info
!terraform/keys/README.md

# Ansible sensitive files
ansible_evilginx/inventory.ini
ansible_evilginx/vault.yml
ansible_evilginx/ansible.log
ansible_evilginx/.ansible/

# AWS and Security
*.key
*.pem
*.crt
*.log
sessions/
data/
certs/
.aws/
~/.aws

# OS and editor files
.DS_Store
Thumbs.db
*.swp
*~
.vscode/
